generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  nouveau
  a_rappeler
  visite_a_planifier
  devis_a_preparer
  devis_envoye
  signe
  gagne
  perdu
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  phone         String
  email         String
  city          String?
  sourceLead    String     @default("website")
  typeProjet    String
  budget        Int?
  status        LeadStatus @default(nouveau)
  maturityScore Int?
  consent       Boolean    @default(false)
  project       Project?
  estimates     Estimate[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Project {
  id          String         @id @default(cuid())
  leadId      String         @unique
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String
  city        String?
  postalCode  String?
  surface     Float?
  details     Json
  photos      ProjectPhoto[]
  createdAt   DateTime       @default(now())
}

model ProjectPhoto {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())
}

model Estimate {
  id            String         @id @default(cuid())
  leadId         String?
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  number         String         @unique
  low            Int
  mid            Int
  high           Int
  duration       String
  complexity     String
  assumptions    Json
  pdfUrl         String?
  lines          EstimateLine[]
  createdAt      DateTime       @default(now())
}

model EstimateLine {
  id         String   @id @default(cuid())
  estimateId String
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  label      String
  quantity   Float
  unit       String
  low        Int
  mid        Int
  high       Int
  reference  String?
  description String?
}

model PriceItem {
  id        String   @id @default(cuid())
  key       String   @unique
  category  String
  label     String
  unit      String
  low       Int
  mid       Int
  high      Int
  reference String?
  description String?
  vatRate   Float    @default(10)
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model PricingSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Realisation {
  id          String             @id @default(cuid())
  title       String
  city        String
  type        String
  description String
  duration    String
  budget      String
  tags        String[]
  active      Boolean            @default(true)
  photos      RealisationPhoto[]
  media       MediaAsset[]
  createdAt   DateTime           @default(now())
}

model RealisationPhoto {
  id            String      @id @default(cuid())
  realisationId String
  realisation   Realisation @relation(fields: [realisationId], references: [id], onDelete: Cascade)
  beforeUrl     String?
  afterUrl      String?
  sortOrder     Int         @default(0)
}

model MediaAsset {
  id            String      @id @default(cuid())
  realisationId String?
  realisation   Realisation? @relation(fields: [realisationId], references: [id], onDelete: SetNull)
  kind          String
  url           String
  title         String?
  alt           String?
  createdAt     DateTime    @default(now())

  @@index([realisationId, createdAt])
}

model Employee {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  role        String
  photoUrl    String?
  bio         String
  specialties String[]
  area        String?
  phone       String?
  email       String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
}

model TrustBadge {
  id        String  @id @default(cuid())
  label     String
  note      String?
  icon      String?
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}

model SiteSettings {
  id       String @id @default(cuid())
  key      String @unique
  value    Json
}

model WebhookEvent {
  id        String   @id @default(cuid())
  name      String
  payload   Json
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String?
  action    String
  entity    String
  entityId  String?
  payload   Json?
  createdAt DateTime @default(now())
}


model SiteEvent {
  id        String   @id @default(cuid())
  event     String
  path      String
  label     String?
  sessionId String?
  referrer  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([path, createdAt])
}
